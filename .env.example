# Copiar este archivo como ".env" y ajustar valores reales.
# En desarrollo local puedes dejar DATABASE_URL sin definir para usar SQLite.

SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Descomentar y configurar en el VPS para usar PostgreSQL:
# DATABASE_URL=postgresql://usuario:password@localhost:5432/sge_enfermeria

# Solo necesario en producción (protección anti fuerza-bruta del login
# compartida entre los workers de Gunicorn). En desarrollo no se usa.
# RATELIMIT_STORAGE_URI=redis://localhost:6379

# Correo para mandar comprobantes de pago (config.py -> MAIL_USERNAME/MAIL_PASSWORD).
# MAIL_PASSWORD es una "contraseña de aplicación" de Gmail, NO tu contraseña
# normal de Google. Se genera en:
# https://myaccount.google.com/security > Verificación en 2 pasos > Contraseñas de aplicaciones
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu-contraseña-de-aplicacion-de-16-caracteres

FLASK_ENV=development